{
  "name": "funnel-graph-js",
  "version": "1.4.2",
  "description": "Vue 3 SVG Funnel Graph Component Library with TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "vue-tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "funnel",
    "chart",
    "graph",
    "funnel-chart",
    "funnel-graph",
    "svg-funnel-chart",
    "svg-funnel-graph",
    "composition-api"
  ],
  "author": "Greg Hovanesyan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vduggen/funnel-graph-js.git"
  },
  "bugs": {
    "url": "https://github.com/vduggen/funnel-graph-js/issues"
  },
  "homepage": "https://github.com/vduggen/funnel-graph-js#readme",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
